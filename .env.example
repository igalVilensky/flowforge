# FlowForge can run without environment variables in rule-only mode.
# Provider keys are optional and never make FlowForge execute workflows.

FLOWFORGE_DEFAULT_MODE=demo
FLOWFORGE_MAX_INPUT_CHARS=4000

# Optional provider keys.
GROQ_API_KEY=
# Optional compile-agent model overrides. Keep these small to avoid provider rate limits.
GROQ_AGENT_MODEL=llama-3.1-8b-instant
GROQ_AGENT_MAX_TOKENS=900
# Optional n8n JSON draft generator key.
GROQ_N8N_API_KEY=
GROQ_N8N_MODEL=openai/gpt-oss-120b
GROQ_N8N_MAX_TOKENS=2200
GEMINI_API_KEY=
GEMINI_AGENT_MODEL=gemini-1.5-flash
GEMINI_AGENT_MAX_OUTPUT_TOKENS=1400
OPENAI_API_KEY=

# Future token budgets.
FLOWFORGE_BALANCED_LLM_CALL_LIMIT=3
FLOWFORGE_FULL_LLM_CALL_LIMIT=4
