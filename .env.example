# FlowForge Milestone 0 does not require environment variables.
# The placeholder compiler never calls external providers.

FLOWFORGE_DEFAULT_MODE=demo
FLOWFORGE_MAX_INPUT_CHARS=4000

# Future provider keys. These are intentionally unused in Milestone 0.
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Future token budgets.
FLOWFORGE_BALANCED_LLM_CALL_LIMIT=3
FLOWFORGE_FULL_LLM_CALL_LIMIT=4
