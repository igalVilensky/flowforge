# FlowForge can run without provider keys in demo/rule-only mode.
# Provider keys are optional and never make FlowForge execute workflows.
#
# Netlify:
# - Add these in Dashboard -> Site settings -> Environment variables.
# - Never prefix provider keys with NUXT_PUBLIC_; only server routes should read them.
# - Do not commit real keys.
#
# Router can use a smaller output budget; Blueprint, Safety, and n8n need larger
# structured JSON budgets. n8n JSON generation may need 4096+ tokens depending
# on the selected model and workflow size.

FLOWFORGE_DEFAULT_MODE=demo
FLOWFORGE_MAX_INPUT_CHARS=4000

# Required for "Suggest an automation" real-world pain-point search.
TAVILY_API_KEY=

# Primary Clarifier and Blueprint Architect provider.
OPENAI_API_KEY=
OPENAI_AGENT_MODEL=gpt-5-nano

# Optional discovery-specific model and output budget overrides.
OPENAI_DISCOVERY_MODEL=gpt-4.1-mini
OPENAI_DISCOVERY_MAX_OUTPUT_TOKENS=3000

# Optional per-agent OpenAI overrides.
OPENAI_CLARIFIER_MODEL=
OPENAI_BLUEPRINT_MODEL=

# Groq provider. Leave per-agent model overrides blank to fall back to GROQ_AGENT_MODEL.
GROQ_API_KEY=
GROQ_AGENT_MODEL=openai/gpt-oss-120b
GROQ_AGENT_MAX_TOKENS=2200

# Optional per-agent Groq overrides.
GROQ_ROUTER_MODEL=
GROQ_ROUTER_MAX_TOKENS=900
GROQ_CLARIFIER_MODEL=
GROQ_CLARIFIER_MAX_TOKENS=1200
GROQ_BLUEPRINT_MODEL=
GROQ_BLUEPRINT_MAX_TOKENS=2600
GROQ_SAFETY_MODEL=
GROQ_SAFETY_MAX_TOKENS=2600

# Optional n8n JSON draft generator key.
GROQ_N8N_API_KEY=
GROQ_N8N_MODEL=openai/gpt-oss-120b
GROQ_N8N_MAX_TOKENS=4096

# Gemini provider. Leave per-agent model overrides blank to fall back to GEMINI_AGENT_MODEL.
GEMINI_API_KEY=
GEMINI_AGENT_MODEL=gemini-2.5-flash-lite
GEMINI_AGENT_MAX_OUTPUT_TOKENS=2200

# Optional per-agent Gemini overrides.
GEMINI_ROUTER_MODEL=
GEMINI_ROUTER_MAX_OUTPUT_TOKENS=900
GEMINI_CLARIFIER_MODEL=
GEMINI_CLARIFIER_MAX_OUTPUT_TOKENS=1200
GEMINI_BLUEPRINT_MODEL=
GEMINI_BLUEPRINT_MAX_OUTPUT_TOKENS=2600
GEMINI_SAFETY_MODEL=
GEMINI_SAFETY_MAX_OUTPUT_TOKENS=2600

FLOWFORGE_BALANCED_LLM_CALL_LIMIT=3
FLOWFORGE_FULL_LLM_CALL_LIMIT=4
